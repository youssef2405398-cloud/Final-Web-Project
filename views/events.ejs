<%- include('partials/header', { title: 'Events' , page: 'events' , pageCss: 'events' }) %>
  <%- include('partials/navbar', { page: 'events' }) %>
    <%- include('partials/toast') %>

      <main class="container">
        <h1 class="page-title">📅 All Events</h1>

        <form class="filters" action="/events" method="GET">
          <input type="text" name="search" placeholder="Search by title, location, or description..."
            value="<%= filters && filters.search ? filters.search : '' %>">
          <select name="category">
            <option value="">All Categories</option>
            <option value="academic" <%=filters && filters.category==='academic' ? 'selected' : '' %>>Academic</option>
            <option value="sports" <%=filters && filters.category==='sports' ? 'selected' : '' %>>Sports</option>

            </div>
            <% } %>
      </main>

      <%- include('partials/footer') %>