<%- include('partials/header', { title: 'Events', page: 'events', pageCss: 'events' }) %>
<%- include('partials/navbar', { page: 'events' }) %>
<%- include('partials/toast') %>

<main class="container">
  <h1 class="page-title">📅 All Events</h1>

  <form class="filters" action="/events" method="GET">
    <input type="text" name="search" placeholder="Search by title, location, or description..." value="<%= filters && filters.search ? filters.search : '' %>">
    <select name="category">
      <option value="">All Categories</option>
      <option value="academic" <%= filters && filters.category === 'academic' ? 'selected' : '' %>>Academic</option>
      <option value="sports" <%= filters && filters.category === 'sports' ? 'selected' : '' %>>Sports</option>
      <option value="cultural" <%= filters && filters.category === 'cultural' ? 'selected' : '' %>>Cultural</option>
      <option value="social" <%= filters && filters.category === 'social' ? 'selected' : '' %>>Social</option>
      <option value="workshop" <%= filters && filters.category === 'workshop' ? 'selected' : '' %>>Workshop</option>
    </select>
    <button type="submit" class="btn btn-primary">Filter</button>
  </form>

  <div class="events-grid">
    <% if (events && events.length > 0) { %>
      <% events.forEach(event => { %>
        <%- include('partials/event-card', { event: event }) %>
      <% }) %>
    <% } else { %>
      <p class="empty-state">No events match your filters. <a href="/events">Clear filters</a></p>
    <% } %>
  </div>

  <% if (pagination && pagination.totalPages > 1) { %>
    <div class="pagination">
      <% if (pagination.hasPrev) { %>
        <a href="?page=<%= pagination.currentPage - 1 %>&<%= new URLSearchParams(filters || {}).toString() %>" class="page-link">← Prev</a>
      <% } else { %>
        <span class="disabled">← Prev</span>
      <% } %>
      
      <% for(let i = 1; i <= pagination.totalPages; i++) { %>
        <%= i === pagination.currentPage ? `<span class="active">${i}</span>` : `<a href="?page=${i}&<%= new URLSearchParams(filters || {}).toString() %>" class="page-link">${i}</a>` %>
      <% } %>
      
      <% if (pagination.hasNext) { %>
        <a href="?page=<%= pagination.currentPage + 1 %>&<%= new URLSearchParams(filters || {}).toString() %>" class="page-link">Next →</a>
      <% } else { %>
        <span class="disabled">Next →</span>
      <% } %>
    </div>
  <% } %>
</main>

<%- include('partials/footer') %>