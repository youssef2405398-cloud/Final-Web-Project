<%- include('partials/header', { title: 'Login', page: 'login', pageCss: 'auth' }) %>
<%- include('partials/navbar') %>
<%- include('partials/toast') %>

<main class="auth-container">
  <div class="auth-card">
    <h1>🔑 Welcome Back</h1>
    <% if (typeof error !== 'undefined' && error) { %>
      <p class="error-msg"><%= error %></p>
    <% } %>
    <form action="/login" method="POST" class="auth-form">
      <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
      <div class="form-group">
        <label for="email">Email Address</label>
        <input type="email" id="email" name="email" required placeholder="you@university.edu" value="<%= values ? values.email : '' %>">
      </div>
      <div class="form-group password-wrapper">
        <label for="password">Password</label>
        <input type="password" id="password" name="password" required placeholder="••••••••">
      </div>
      <button type="submit" class="btn btn-primary btn-block">Login</button>
    </form>
    <p class="auth-switch">Don't have an account? <a href="/signup">Create one</a></p>
  </div>
</main>

<%- include('partials/footer') %>