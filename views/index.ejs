<%- include('partials/header', { title: 'Home', page: 'home', pageCss: 'homepage' }) %>
<%- include('partials/navbar', { page: 'home' }) %>
<%- include('partials/toast') %>

<main>
  <section class="hero">
    <div class="container hero-content">
      <h1>Discover Campus Events</h1>
      <p>Connect, learn, and grow with your university community. Find workshops, socials, and academic gatherings all in one place.</p>
      <div class="hero-cta">
        <a href="/events" class="btn btn-primary btn-lg">Browse Events</a>
        <% if (!user || !user.userId) { %>
          <a href="/signup" class="btn btn-outline btn-lg">Join Free</a>
        <% } %>
      </div>
    </div>
  </section>

  <section class="container">
    <div class="section-header">
      <h2>🔥 Upcoming Events</h2>
      <a href="/events" class="view-all">View All →</a>
    </div>
    <div class="events-grid">
      <% if (featuredEvents && featuredEvents.length > 0) { %>
        <% featuredEvents.forEach(event => { %>
          <%- include('partials/event-card', { event: event }) %>
        <% }) %>
      <% } else { %>
        <p class="empty-state">No upcoming events. Be the first to <a href="/create-event">create one!</a></p>
      <% } %>
    </div>
  </section>
</main>

<%- include('partials/footer') %>