<%- include('partials/header', { title: title, page: page, pageCss: pageCss }) %>
  <%- include('partials/navbar', { page: page }) %>
    <%- include('partials/toast') %>

      <main class="container event-detail-page">
        <div class="event-detail-header">
          <h1 class="page-title">
            <%= event.title %>
          </h1>
          <div class="event-badges">
            <span class="badge <%= event.category %>">
              <%= event.category %>
            </span>
          </div>
        </div>

        <% } else { %>
          <a href="/login?redirect=/events/<%= event._id %>" class="btn btn-outline btn-block">Log in to RSVP</a>
          <% } %>
            </div>
            </div>
            </div>
            </div>

            <div class="event-description">
              <h2>About This Event</h2>
              <div class="description-text">
                <% if (event.description) { %>
                  <% const paragraphs=event.description.split('\n'); %>
                    <% paragraphs.forEach(p=> { %>
                      <% if (p.trim()) { %>
                        <p>
                          <%= p %>
                        </p>
                        <% } %>
                          <% }) %>
                            <% } else { %>
                              <p>No description provided for this event.</p>
                              <% } %>
              </div>
            </div>
      </main>

      <%- include('partials/footer') %>