<%- include('partials/header', { title: title, page: page, pageCss: pageCss }) %>
<%- include('partials/navbar', { page: page }) %>
<%- include('partials/toast') %>

<main class="container event-detail-page">
  <div class="event-detail-header">
    <h1 class="page-title"><%= event.title %></h1>
    <div class="event-badges">
      <span class="badge <%= event.category %>"><%= event.category %></span>
    </div>
  </div>

  <div class="event-detail-content">
    <div class="event-image-container">
      <img src="<%= event.imageUrl || '/images/default-event.jpg' %>" alt="<%= event.title %>" class="event-main-image" onerror="this.src='/images/default-event.jpg'">
    </div>

    <div class="event-info-sidebar">
      <div class="info-card">
        <h3>Event Details</h3>
        <ul class="info-list">
          <li><strong>📅 Date:</strong> <%= new Date(event.date).toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %></li>
          <li><strong>⏰ Time:</strong> <%= event.time %></li>
          <li><strong>📍 Location:</strong> <%= event.location %></li>
          <li><strong>👤 Organizer:</strong> <%= event.organizer %></li>
        </ul>
        
        <div class="availability-status">
          <h4>Availability</h4>
          <p>
            <strong><%= event.availableSeats %></strong> seats remaining 
            (out of <%= event.maxAttendees %>)
          </p>
          <% if (event.availableSeats <= 0) { %>
            <div class="alert alert-danger">This event is full.</div>
          <% } else if (event.availableSeats <= 20) { %>
            <div class="alert alert-warning">Hurry! Only a few seats left.</div>
          <% } %>
        </div>

        <div class="action-buttons">
          <% if (user && user.userId) { %>
            <% if (typeof hasRSVPed !== 'undefined' && hasRSVPed) { %>
              <div class="alert alert-success" style="text-align: center; margin-bottom: 1rem; background: rgba(16, 185, 129, 0.15); color: var(--success); padding: 0.75rem; border-radius: 8px;">
                🎉 You are registered for this event!
              </div>
              <form action="/cancel-rsvp/<%= event._id %>" method="POST">
                <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                <button type="submit" class="btn btn-danger btn-block">Cancel RSVP</button>
              </form>
            <% } else { %>
              <% if (event.availableSeats > 0) { %>
                <a href="/rsvp/<%= event._id %>" class="btn btn-primary btn-block">RSVP Now</a>
              <% } else { %>
                <button class="btn btn-secondary btn-block" disabled>Event Full</button>
              <% } %>
            <% } %>
          <% } else { %>
            <a href="/login?redirect=/events/<%= event._id %>" class="btn btn-outline btn-block">Log in to RSVP</a>
          <% } %>
        </div>
      </div>
    </div>
  </div>

  <div class="event-description">
    <h2>About This Event</h2>
    <div class="description-text">
      <% if (event.description) { %>
        <% const paragraphs = event.description.split('\n'); %>
        <% paragraphs.forEach(p => { %>
          <% if (p.trim()) { %>
            <p><%= p %></p>
          <% } %>
        <% }) %>
      <% } else { %>
        <p>No description provided for this event.</p>
      <% } %>
    </div>
  </div>
</main>

<%- include('partials/footer') %>
